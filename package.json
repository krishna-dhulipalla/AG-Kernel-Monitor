{
  "name": "ag-kernel-monitor",
  "displayName": "Antigravity Token Monitor",
  "publisher": "Krishnadhulipalla",
  "version": "1.2.1",
  "description": "Token consumption, turn growth, context bloat, and cache monitoring for Antigravity sessions",
  "icon": "media/icon.png",
  "type": "module",
  "main": "./vscode/extension.cjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agKernelMonitor",
          "title": "AG Token Monitor",
          "icon": "vscode/media/activity.svg"
        }
      ]
    },
    "views": {
      "agKernelMonitor": [
        {
          "type": "webview",
          "id": "agKernelMonitor.sidebar",
          "name": "Token Monitor",
          "icon": "vscode/media/activity.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "agKernelMonitor.refresh",
        "title": "Refresh Monitor",
        "icon": "$(refresh)"
      },
      {
        "command": "agKernelMonitor.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "agKernelMonitor.forceClean",
        "title": "Clean Heavy Sessions"
      },
      {
        "command": "agKernelMonitor.openOutput",
        "title": "AG Token Monitor: Open Output"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agKernelMonitor.refresh",
          "when": "view == agKernelMonitor.sidebar",
          "group": "navigation"
        },
        {
          "command": "agKernelMonitor.openSettings",
          "when": "view == agKernelMonitor.sidebar",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "AG Token Monitor",
      "properties": {
        "agKernelMonitor.bunPath": {
          "type": "string",
          "default": "bun",
          "description": "Deprecated for the extension runtime. Only relevant for local CLI development or fallback workflows."
        },
        "agKernelMonitor.cliConfigPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to an Antigravity Token Monitor config file. Relative paths resolve from the first workspace folder."
        },
        "agKernelMonitor.autoRefreshSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Fallback full-refresh interval in seconds. Live updates run while the sidebar is visible."
        },
        "agKernelMonitor.preferActiveEditorWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Prefer the workspace containing the active editor when choosing the workspace details panel."
        }
      }
    }
  },
  "bin": {
    "agk": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "start": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outdir dist --target bun",
    "build:vsx-cli": "bun build src/cli/index.ts --outfile vscode/runtime/agk-cli.js --target bun",
    "build:runtime-binaries": "bun run scripts/build-platform-binaries.ts",
    "build:runtime-binary:local": "bun run scripts/build-local-runtime.ts",
    "build:vsix-universal": "node --check vscode/extension.cjs",
    "package:vsix": "bun run build:vsix-universal && bun run scripts/package-vsix.ts",
    "test": "bun test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@vscode/vsce": "^3.6.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/krishna-dhulipalla/AG-Kernel-Monitor"
  },
  "keywords": [
    "antigravity",
    "token-monitor",
    "telemetry",
    "context-bloat",
    "cli"
  ],
  "license": "MIT"
}
